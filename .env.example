# Copy this file to .env (same folder) and fill in the values from your
# Supabase project: Project Settings -> API.
# After saving, restart `npm start` so CRA picks up the new env vars.

REACT_APP_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
REACT_APP_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
